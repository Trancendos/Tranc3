# ── TranceFlow (tranceflow, Port 8052) — 3D Modeling & Games Studio ──────────
TRANCEFLOW_PORT=8052
TRANCEFLOW_DB_PATH=/data/tranceflow.db
TRANCEFLOW_ASSET_DIR=/data/tranceflow-assets
GODOT_BIN=godot                            # Godot Engine binary (self-hosted, MIT)
BLENDER_BIN=blender                        # Blender binary (self-hosted, GPL)
TRANCEFLOW_GODOT=1                         # Enable Godot backend
TRANCEFLOW_BLENDER=1                       # Enable Blender backend
TRANCEFLOW_TRIMESH=1                       # Enable trimesh backend (MIT)
TRANCEFLOW_MESHIO=1                        # Enable meshio backend (MIT)
TRANCEFLOW_OPEN3D=1                        # Enable open3d backend (MIT)
TRANCEFLOW_PYVISTA=1                       # Enable pyvista backend (MIT)
TRANCEFLOW_QUOTA_MAX_CALLS=10000
TRANCEFLOW_QUOTA_WINDOW=3600
TRANCEFLOW_PHEROMONE_DECAY=0.05
TRANCEFLOW_PROCESS_TIMEOUT=120.0

# ── VRAR3D (vrar3d, Port 8063) — Standalone 3D/VR Immersion Platform ─────────
VRAR3D_PORT=8063
VRAR3D_DB_PATH=/data/vrar3d.db
VRAR3D_ASSET_DIR=/data/assets
VRAR3D_TRIMESH=1                           # Enable trimesh backend (MIT)
VRAR3D_OPEN3D=1                            # Enable open3d backend (MIT)
VRAR3D_BLENDER=1                           # Enable Blender headless backend (GPL)
VRAR3D_GODOT=1                             # Enable Godot headless backend (MIT)
VRAR3D_PYVISTA=1                           # Enable pyvista backend (MIT)
VRAR3D_MESHIO=1                            # Enable meshio backend (MIT)
SKETCHFAB_API_KEY=                         # Sketchfab free API key (optional, rate-limited)
VRAR3D_SKETCHFAB_LIMIT=100                 # Hard stop for Sketchfab calls/hr
VRAR3D_QUOTA_MAX_CALLS=10000
VRAR3D_QUOTA_WINDOW=3600
VRAR3D_PHEROMONE_DECAY=0.05
VRAR3D_PROCESS_TIMEOUT=60.0
# Client-side renderer CDN URLs (all free/OSS)
THREEJS_CDN=https://cdn.jsdelivr.net/npm/three@0.169.0/build/three.module.js
BABYLONJS_CDN=https://cdn.babylonjs.com/babylon.js
AFRAME_CDN=https://aframe.io/releases/1.6.0/aframe.min.js
MODEL_VIEWER_CDN=https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js
VRAR3D_RENDERER_PRIORITY=threejs,babylonjs,aframe,model-viewer
