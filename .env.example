# ═══════════════════════════════════════════════════════════════════
# TRANC3 Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Database ──────────────────────────────────────────────────────
# SQLite (development): sqlite:///./tranc3_dev.db
# PostgreSQL (production): postgresql://user:pass@localhost:5432/tranc3
DATABASE_URL=sqlite:///./tranc3_dev.db

# ── Redis ─────────────────────────────────────────────────────────
# Redis is optional but recommended for rate limiting and caching.
# If not set, in-memory fallbacks are used.
REDIS_URL=redis://localhost:6379/0

# ── LLM Provider API Keys ────────────────────────────────────────
# At least ONE provider should be configured for inference to work.
# Priority: Local → HuggingFace (free) → Groq (free) → OpenAI (paid)

# HuggingFace Inference API — free tier, ~30 requests/minute
# Get key at: https://huggingface.co/settings/tokens
HF_API_KEY=
HF_MODEL_ID=microsoft/phi-3-mini-4k-instruct

# Groq Cloud — free tier available, very fast inference
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL_ID=llama-3.1-8b-instant

# OpenAI-compatible endpoint — paid, last resort
# Also works with local Ollama, vLLM, etc.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_ID=gpt-3.5-turbo

# ── Local Model (optional) ───────────────────────────────────────
# Path to trained Tranc3 model weights
# Run `python train.py` to train from scratch
TRANC3_MODEL_PATH=./models/tranc3-v1/tranc3-final.pt
TRANC3_TOKENIZER_PATH=./models/tokenizer

# ── Application Settings ─────────────────────────────────────────
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
PRIMARY_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr,de,zh,ja
ENABLE_EMOTION=true
DEFAULT_PERSONALITY=tranc3-base

# ── Stripe (optional — for billing) ───────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Observability (optional) ─────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
