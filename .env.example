# TRANC3 Environment Variables — copy to .env and fill in values
# NEVER commit .env to git

# API
SECRET_KEY=your-secret-key-here
ENVIRONMENT=development
DEBUG=false
PORT=8000

# Database (Supabase free tier)
# Project ref available at: app.supabase.com/project/<ref>/settings/database
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=eyJ...  # Settings → API → anon public
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Settings → API → service_role (keep secret)

# Cache (Upstash Redis free tier)
REDIS_URL=rediss://:[password]@[endpoint].upstash.io:6379

# Vector DB (Pinecone free tier)
PINECONE_API_KEY=your-pinecone-key
PINECONE_ENV=gcp-starter

# Payments — Stripe (primary, 1.4%+20p EU / 2.9%+30¢ US, free to integrate)
# Get real price IDs from: Stripe Dashboard → Products → Add Product → Add Price
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...          # must be a real price_xxx ID, not a placeholder
STRIPE_BUSINESS_PRICE_ID=price_...     # must be a real price_xxx ID, not a placeholder

# Payments — Lemon Squeezy (fallback, 5%+50¢, free to integrate)
# https://app.lemonsqueezy.com/settings/api
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_PRO_VARIANT_ID=
LEMON_BUSINESS_VARIANT_ID=

# Payments — Paddle (fallback, 5%+50¢, free to integrate)
# https://vendors.paddle.com/api-keys
PADDLE_VENDOR_ID=
PADDLE_API_KEY=
PADDLE_PRO_PRICE_ID=
PADDLE_BUSINESS_PRICE_ID=

# Frontend
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8000

# PostHog analytics (zero-cost, 1M events/month free tier)
# Get your key from https://eu.posthog.com — project 96100 on trancendos.com
VITE_POSTHOG_KEY=phc_your_project_api_key_here
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# CORS (comma-separated; use * only for dev, set specific domains in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT  (REQUIRED — generate: python -c "import secrets; print(secrets.token_hex(32))")
# API will HARD FAIL on startup if this is missing or < 32 chars
JWT_SECRET=CHANGE_ME_generate_with_python_secrets_token_hex_32

# Audit Ledger signing key (REQUIRED for cross-restart token verification)
# Without this, AuditLedger generates a persistent key file in logs/audit/.audit_signing_key
# on first start (survives restarts, single-node OK). Set this env var for:
#   - Multi-node / HA deployments (all nodes must share the same key)
#   - Disaster recovery (verify old ledger data after restore)
#   - Compliance audits requiring external verification
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Or run:   python scripts/generate_env.py  (auto-generates and writes to .env)
AUDIT_SIGNING_KEY=CHANGE_ME_generate_with_python_secrets_token_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Model
MODEL_PATH=./models/tranc3-base
TOKENIZER_MODEL=bert-base-multilingual-cased
CACHE_DIR=./cache

# ─── Zero-Cost AI Inference Stack (10 providers, adaptive rotation) ──────────
# Priority: llama.cpp → vLLM → Ollama → Groq → Gemini → Cerebras →
#           Cloudflare AI → SambaNova → OpenRouter → HuggingFace → Offline

# Tier 0: Self-hosted (unlimited, no API key, fully free)
# llama.cpp server — CPU-only, any GGUF model, minimal RAM
LLAMACPP_BASE_URL=http://localhost:8091
LLAMACPP_MODEL_FILE=llama-3.2-3b-instruct.Q4_K_M.gguf

# vLLM — GPU-accelerated, any HuggingFace model (Docker profile: gpu)
VLLM_BASE_URL=http://localhost:8090/v1
VLLM_DEFAULT_MODEL=meta-llama/Llama-3.2-3B-Instruct

# Tier 0: Ollama — local self-hosted LLM (install: curl -fsSL https://ollama.com/install.sh | sh)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Tier 2: Groq — free tier (14,400 req/day, ultra-low latency LPU)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Tier 3: Gemini — free tier (1,500 req/day, 1M token context)
GOOGLE_GEMINI_API_KEY=

# Tier 4: Cerebras — free tier (1M tokens/day, fast RDU inference)
CEREBRAS_API_KEY=

# Tier 5: SambaNova — free tier (large models up to 405B)
SAMBANOVA_API_KEY=

# Tier 6: Cloudflare Workers AI — free tier (10,000 neurons/day)
CF_ACCOUNT_ID=
CF_AI_API_TOKEN=
CF_AI_DEFAULT_MODEL=@cf/meta/llama-3.1-8b-instruct

# Tier 7: OpenRouter — 20+ free models (DeepSeek R1, Llama, Qwen)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Tier 8: HuggingFace Inference API — free tier (rate-limited)
HF_API_TOKEN=
HF_API_KEY=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Near-zero cost (honest: NOT free — $5 trial then paid)
TOGETHER_API_KEY=

# Vector store
EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DIM=384
VECTOR_STORE_DIR=./data/vector_store

# Feature Flags
ENABLE_QUANTUM=true
ENABLE_CONSCIOUSNESS=true
ENABLE_NEUROMORPHIC=false
ENABLE_SELF_EVOLUTION=true
ENABLE_SWARM=false

# Observability — self-hosted stack (zero-cost)
# OpenTelemetry Collector (traces/metrics/logs → Tempo/VictoriaMetrics/Loki)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_ENABLED=true
OTEL_SERVICE_NAME=tranc3
# Grafana (self-hosted at :3001 — no cloud key needed for self-hosted)
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_generate_strong_password
GRAFANA_CLOUD_API_KEY=
# Prometheus / AlertManager
PROMETHEUS_URL=http://prometheus:9090
ALERTMANAGER_URL=http://alertmanager:9093
# Alertmanager notification routing (optional — set to enable Slack alerts)
ALERTMANAGER_SLACK_WEBHOOK=
# Loki / Tempo
LOKI_URL=http://loki:3100
TEMPO_URL=http://tempo:3200
# VictoriaMetrics (long-term metrics storage)
VICTORIA_METRICS_URL=http://victoriametrics:8428

# Magna Carta Framework — full config block is at the bottom of this file

# The Citadel — Forgejo webhook receiver
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# Set in Forgejo: Settings → Webhooks → Secret
CITADEL_WEBHOOK_SECRET=your-webhook-secret-here

# DevOcity — developer portal
# No additional secrets needed; keys are issued and hashed at runtime

# Supabase additional keys (auto-populated from supabase CLI or dashboard)
SUPABASE_JWT_SECRET=  # Settings → API → JWT Settings → JWT Secret

# ── Additional Worker/Service URLs ──
# Internal service URLs (auto-configured in docker-compose; override for bare-metal)
INFINITY_ONE_URL=http://localhost:8002
USERS_SERVICE_URL=http://localhost:8006
PAYMENTS_SERVICE_URL=http://localhost:8013
PRODUCTS_SERVICE_URL=http://localhost:8011
ORDERS_SERVICE_URL=http://localhost:8012

# ── Additional Feature Flags ──
ENABLE_EVOLUTION=true
ENABLE_HOLOGRAPHIC=false
ENABLE_QUANTUM_OPT=false

# ── Additional Settings ──
LOG_LEVEL=INFO
JWT_EXPIRY_MINUTES=60
REFRESH_EXPIRY_DAYS=7
REQUIRE_AUTH=true
RATE_LIMIT_PER_MINUTE=60
HEALTH_CHECK_INTERVAL_SEC=30
AUTH_DATABASE_PATH=./data/auth.db
VOID_DATA_DIR=./data/void

# ── Vector DB Alternatives ──
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=  # Only for Qdrant Cloud; leave empty for self-hosted
PINECONE_INDEX=tranc3
EMBED_URL=http://localhost:8000/embed

# ── Cloud Provider Flags (enable for cloud storage) ──
AWS_ENABLED=false
AZURE_ENABLED=false
GCP_ENABLED=false

# ── Internal Security ──
INTERNAL_SECRET=  # REQUIRED for The Void vault — generate: python -c "import secrets; print(secrets.token_hex(32))"
IP_PROTECTION_KEY=  # Key for IP protection features
MASTER_KEY_SEED=generate-another-32-byte-random-hex-value  # REQUIRED for The Void vault
BACKUP_API_TOKEN=  # Token for backup API access

# ── Nanoservice Port ──
NANO_PORT=8001

# ── Cluster Config ──
PRIMARY_CLUSTER=local

# ─────────────────────────────────────────────────────────────────────────────
# Zero-Cost Extended Platform Services
# All services below are free / self-hosted with no usage billing
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Provider Keys (all have free tiers) ──
GOOGLE_GEMINI_API_KEY=     # Free: gemini-1.5-flash, 15 RPM, 1M TPD — aistudio.google.com
CEREBRAS_API_KEY=          # Free: llama3.1-8b, 60 RPM — cloud.cerebras.ai
SAMBANOVA_API_KEY=         # Free: Meta-Llama-3.1-8B-Instruct, 80 RPD — cloud.sambanova.ai
DEEPSEEK_API_KEY=          # Free tier: deepseek-chat — platform.deepseek.com

# ── NATS JetStream (self-hosted, Apache 2.0) ──
NATS_URL=nats://localhost:4222
NATS_STREAM_NAME=TRANC3
NATS_CONSUMER_NAME=tranc3-event-bus

# ── OpenBao / Vault (self-hosted, MPL 2.0 — The Void) ──
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=              # Set after vault init; see workers/vault-service/README.md
VAULT_NAMESPACE=          # Enterprise only; leave empty for community edition
OPENBAO_ADDR=http://localhost:8200

# ── Langfuse AI Observability (self-hosted, MIT) ──
LANGFUSE_PUBLIC_KEY=      # Generated from Langfuse UI after first login
LANGFUSE_SECRET_KEY=      # Generated from Langfuse UI after first login
LANGFUSE_HOST=http://localhost:3002
LANGFUSE_SECRET=          # Random string for NextAuth — generate: python -c "import secrets; print(secrets.token_hex(32))"
LANGFUSE_SALT=            # Random string for password hashing — generate: python -c "import secrets; print(secrets.token_hex(32))"

# ── Woodpecker CI (self-hosted, Apache 2.0) ──
FORGEJO_URL=http://forgejo:3000
WOODPECKER_FORGEJO_CLIENT= # OAuth app client ID from Forgejo
WOODPECKER_FORGEJO_SECRET= # OAuth app client secret from Forgejo
WOODPECKER_SECRET=         # Shared secret — generate: python -c "import secrets; print(secrets.token_hex(32))"
WOODPECKER_AGENT_TOKEN=    # Agent token from Woodpecker UI

# ── KrakenD API Gateway (self-hosted, Apache 2.0) ──
KRAKEND_JWT_SECRET=       # Must match JWT_SECRET above

# ── Penpot Design Platform (self-hosted, MPL 2.0 — Fabulousa) ──
PENPOT_SECRET_KEY=        # generate: python -c "import secrets; print(secrets.token_hex(32))"

# ── OWASP Dependency-Track SBOM Monitoring (self-hosted, Apache 2.0) ──
DTRACK_URL=http://localhost:8081
DTRACK_API_KEY=           # Generated from Dependency-Track UI → Teams → Automation → API Keys

# ── Grafana Tempo (self-hosted, AGPLv3) ──
TEMPO_URL=http://localhost:3200

# ── VictoriaMetrics (self-hosted, Apache 2.0) ──
VICTORIA_METRICS_URL=http://localhost:8428

# ── Valkey (self-hosted, BSD-3 — Redis replacement) ──
VALKEY_URL=redis://localhost:6379

# ── Oracle Cloud Always Free (optional — zero cost) ──
# 4 OCPU / 24 GB RAM Ampere ARM instance — free forever
# OCI_CLI_USER=ocid1.user.oc1..xxx
# OCI_CLI_TENANCY=ocid1.tenancy.oc1..xxx
# OCI_CLI_FINGERPRINT=xx:xx:xx:...
# OCI_CLI_KEY_FILE=~/.oci/oci_api_key.pem
# OCI_CLI_REGION=uk-london-1

# ── Azure Free Tier (optional — 12 months free + always free) ──
# Azure SQL: 32 GB storage free per database, up to 10 databases
# AZURE_SQL_CONNECTION_STRING=Server=xxx.database.windows.net;...
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...

# ── pgvector (PostgreSQL extension — zero additional cost) ──
PGVECTOR_TABLE=tranc3_embeddings
PGVECTOR_DIM=384

# ── ChronosSphere / ArcStream — Scheduling federation (8-backend ACO) ──
# Backend 1: Cal.com — self-hosted booking/scheduling (MIT, port 3010)
CALCOM_URL=http://calcom:3000
CALCOM_API_KEY=                  # Cal.com API key from /settings/developer/api-keys
CALCOM_DB_PASSWORD=              # generate: python -c "import secrets; print(secrets.token_hex(16))"
CALCOM_NEXTAUTH_SECRET=          # generate: python -c "import secrets; print(secrets.token_hex(32))"
CALCOM_ENCRYPTION_KEY=           # MUST be exactly 32 chars: python -c "import secrets; print(secrets.token_hex(16))"
CALCOM_EMAIL_FROM=noreply@trancendos.com
CALCOM_THRESHOLD_RPM=60          # hard stop: max requests/min before ACO skips this backend

# Backend 2: Kestra — open-source workflow + cron scheduler (Apache 2.0, port 8060)
KESTRA_URL=http://kestra:8080
KESTRA_NAMESPACE=trancendos.chronos
KESTRA_THRESHOLD_RPM=120

# Backend 3: n8n — workflow automation (Fair-code, port 5678)
N8N_URL=http://n8n:5678
N8N_USER=admin
N8N_PASSWORD=                    # generate: python -c "import secrets; print(secrets.token_hex(16))"
N8N_ENCRYPTION_KEY=              # generate: python -c "import secrets; print(secrets.token_hex(32))"
N8N_THRESHOLD_RPM=60

# Backend 4: APScheduler — in-process SQLite (always-available fallback)
# No config needed — embedded in cron-service worker

# Backend 5: Forgejo (The Workshop) — cron-trigger via CI pipeline (MIT)
FORGEJO_URL=http://forgejo:3456
FORGEJO_TOKEN=                   # Forgejo user API token
FORGEJO_THRESHOLD_RPM=30

# Backend 6: NATS JetStream — delayed-message queue (Apache 2.0)
# NATS_URL already defined above
NATS_JETSTREAM_THRESHOLD_RPM=200

# Backend 7: Valkey — sorted-set scheduled queue (BSD)
# REDIS_URL / Valkey already defined above
VALKEY_SCHEDULE_THRESHOLD_RPM=500

# Backend 8: system cron — python-crontab OS-level fallback
# No external config — writes /etc/cron.d/ if available inside container

# ACO pheromone routing config
CHRONOS_ACO_DECAY=0.15           # pheromone evaporation rate per minute
CHRONOS_ACO_MIN_PHEROMONE=0.05  # floor — backend never fully excluded
CHRONOS_WINDOW_SECONDS=60        # ThresholdGuard sliding-window duration

# ── Outline / The Library (self-hosted wiki, BSL) ──
OUTLINE_URL=http://localhost:3011
OUTLINE_DB_PASSWORD=             # generate: python -c "import secrets; print(secrets.token_hex(16))"
OUTLINE_SECRET_KEY=              # MUST be 32+ chars: python -c "import secrets; print(secrets.token_hex(32))"
OUTLINE_UTILS_SECRET=            # generate: python -c "import secrets; print(secrets.token_hex(32))"

# ── SigNoz / The Observatory enhanced (OpenTelemetry APM, Apache 2.0) ──
SIGNOZ_CLICKHOUSE_PASSWORD=      # generate: python -c "import secrets; print(secrets.token_hex(16))"
# OTEL_EXPORTER_OTLP_ENDPOINT and OTEL_EXPORTER_OTLP_PROTOCOL are defined above.

# ── Creative Workers ──
BLENDER_PATH=/usr/bin/blender     # Auto-detected; override if non-standard
TRIPOSR_MODEL_DIR=/app/models/triposr
FFMPEG_PATH=/usr/bin/ffmpeg       # Auto-detected; override if non-standard

# ── Magna Carta Compliance Framework (https://github.com/Trancendos/Magna-Carta) ──
# Clone or submodule: git submodule add https://github.com/Trancendos/Magna-Carta compliance/magna-carta
# Then set the paths below:
MAGNA_CARTA_ENABLED=false
# Set to true to activate runtime rule enforcement (advisory by default)
# Path to the magna_carta_config.json from the Magna Carta repo:
MAGNA_CARTA_CONFIG_PATH=./compliance/magna-carta/config/magna_carta_config.json
# Optional: path to magna_carta_register.yaml for merged compliance reporting:
MAGNA_CARTA_REGISTER_PATH=./compliance/magna-carta/compliance/magna_carta_register.yaml
# Emit structured audit events for every Magna Carta check (recommended: true in production):
MAGNA_CARTA_AUDIT=true

# ── CranBania / The Town Hall (https://github.com/Trancendos/CranBania) ──
# Self-hosted Kanban + ITSM + Agile board — The Town Hall entity on Port 8071
CRANBANIA_PORT=8071
CRANBANIA_DATA_DIR=/app/data/cranbania
CRANBANIA_API_KEY=                # generate: python -c "import secrets; print(secrets.token_hex(32))"
CRANBANIA_CRON_SECRET=            # generate: python -c "import secrets; print(secrets.token_hex(32))"
# Forgejo integration (The Workshop webhooks → The Town Hall):
CRANBANIA_FORGEJO_URL=http://forgejo:3000
CRANBANIA_WEBHOOK_SECRET=         # Shared secret for Forgejo → CranBania webhooks
# Observatory / audit integration:
CRANBANIA_OBSERVATORY_URL=http://monitoring-worker:8007

