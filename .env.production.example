# TRANC3 — Production Environment Variables
# Copy to .env.production
# NEVER commit .env files to git — use The Void (vault-service) in production
#
# Production environment: maximum security, strict CORS, no debug output,
# all secrets from Vault, live Stripe keys, dedicated PostgreSQL cluster.
#
# Key differences from UAT/Dev:
#   - All secrets MUST come from Vault (VAULT_ADDR + VAULT_TOKEN required)
#   - DEBUG=false enforced
#   - Stripe LIVE keys (sk_live_...)
#   - JWT 60-min expiry (short-lived for security)
#   - CORS locked to exact production domain
#   - All observability exporters active
#   - Rate limiting and circuit breakers at full sensitivity

# ─── Core ──────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
PORT=8000
# MUST be generated and stored in Vault — not set here directly in production
SECRET_KEY=LOAD_FROM_VAULT__tranc3/secret/app/secret_key
LOG_LEVEL=WARNING

# ─── Database ───────────────────────────────────────────────────────────────
# Production: Supabase PostgreSQL (connection pooling enabled)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres?pgbouncer=true
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=LOAD_FROM_VAULT__tranc3/secret/supabase/anon_key
SUPABASE_SERVICE_ROLE_KEY=LOAD_FROM_VAULT__tranc3/secret/supabase/service_role_key

# ─── Cache ──────────────────────────────────────────────────────────────────
# Production: Upstash Redis TLS (rediss://)
REDIS_URL=LOAD_FROM_VAULT__tranc3/secret/redis/url

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=LOAD_FROM_VAULT__tranc3/secret/app/jwt_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60   # Short-lived for production security

# ─── CORS ───────────────────────────────────────────────────────────────────
# Production: locked to exact domains only — no wildcards
CORS_ORIGINS=https://trancendos.com,https://api.trancendos.com
FRONTEND_URL=https://trancendos.com
VITE_API_URL=https://api.trancendos.com

# ─── AI Inference ───────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text
OPENROUTER_API_KEY=LOAD_FROM_VAULT__tranc3/secret/ai/openrouter_key
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
HF_API_KEY=LOAD_FROM_VAULT__tranc3/secret/ai/hf_key
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ─── Model / Embeddings ─────────────────────────────────────────────────────
MODEL_PATH=/app/models/tranc3-base
TOKENIZER_MODEL=bert-base-multilingual-cased
CACHE_DIR=/app/cache
EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DIM=384
VECTOR_STORE_DIR=/app/data/vector_store

# ─── Vector DB ──────────────────────────────────────────────────────────────
PINECONE_API_KEY=LOAD_FROM_VAULT__tranc3/secret/pinecone/api_key
PINECONE_ENV=gcp-starter
PINECONE_NAMESPACE=production

# ─── Payments (LIVE keys — handle with extreme care) ────────────────────────
STRIPE_SECRET_KEY=LOAD_FROM_VAULT__tranc3/secret/stripe/live_secret_key
STRIPE_WEBHOOK_SECRET=LOAD_FROM_VAULT__tranc3/secret/stripe/webhook_secret
STRIPE_PRO_PRICE_ID=price_...   # Live price ID from Stripe dashboard
STRIPE_BUSINESS_PRICE_ID=price_...

# ─── Feature Flags (production — conservative defaults) ─────────────────────
ENABLE_QUANTUM=false         # Enable only after thorough UAT validation
ENABLE_CONSCIOUSNESS=true
ENABLE_NEUROMORPHIC=false    # Experimental — disabled in prod until stable
ENABLE_SELF_EVOLUTION=false  # Requires human oversight gate in prod
ENABLE_SWARM=false

# ─── Workers ────────────────────────────────────────────────────────────────
TRANC3_BACKEND_URL=https://api.trancendos.com
INFINITY_WS_URL=http://tranc3-ws:8004
INFINITY_AUTH_URL=http://tranc3-auth:8005
INFINITY_AI_URL=http://tranc3-ai:8009

# ─── Observability ──────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://tranc3-otel:4317
GRAFANA_CLOUD_API_KEY=LOAD_FROM_VAULT__tranc3/secret/observability/grafana_key
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ─── The Void (Vault — required in production) ──────────────────────────────
VAULT_ADDR=http://tranc3-vault:8200
VAULT_TOKEN=LOAD_FROM_SHAMIR_UNSEAL  # See infra/vault/ for unseal procedure
VAULT_NAMESPACE=tranc3

# ─── Forgejo (The Workshop) ─────────────────────────────────────────────────
FORGEJO_URL=https://trancendos.com/the-workshop
FORGEJO_TOKEN=LOAD_FROM_VAULT__tranc3/secret/forgejo/deploy_token

# ─── Platform ───────────────────────────────────────────────────────────────
MAGNA_CARTA_ENABLED=true
MAGNA_CARTA_CONFIG_PATH=/app/magna_carta_config.json
TRANC3_AUTH_URL=https://auth.trancendos.com
ALLOWED_ORIGINS=https://trancendos.com,https://api.trancendos.com

# ─── Cloudflare (legacy — being decommissioned) ─────────────────────────────
# CF_API_TOKEN=LOAD_FROM_VAULT__tranc3/secret/cloudflare/api_token
# CF_ACCOUNT_ID=e0214028cb64d31232f5662548a55e4e

# ─── Security ───────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict
