{
  "$schema": "https://www.krakend.io/schema/v2.7/krakend.json",
  "version": 3,
  "name": "Trancendos API Gateway",
  "timeout": "30s",
  "cache_ttl": "300s",
  "output_encoding": "json",
  "extra_config": {
    "security/cors": {
      "allow_origins": ["*"],
      "allow_methods": ["GET", "HEAD", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
      "allow_headers": [
        "Origin",
        "Authorization",
        "Content-Type",
        "Accept",
        "X-Internal-Secret",
        "X-Request-ID"
      ],
      "expose_headers": ["Content-Length", "Content-Type"],
      "max_age": "12h"
    },
    "telemetry/metrics": {
      "collection_time": "60s",
      "proxy_disabled": false,
      "router_disabled": false,
      "backend_disabled": false,
      "endpoint_disabled": false,
      "listen_address": ":8090"
    },
    "telemetry/logging": {
      "level": "INFO",
      "prefix": "[KRAKEND]",
      "syslog": false,
      "stdout": true
    },
    "router": {
      "return_error_msg": false
    }
  },
  "endpoints": [

    {
      "endpoint": "/api/v1/auth/{path}",
      "method": "GET",
      "timeout": "30s",
      "output_encoding": "no-op",
      "extra_config": {
        "qos/ratelimit/router": {
          "max_rate": 100,
          "strategy": "ip",
          "client_max_rate": 100,
          "every": "60s"
        }
      },
      "backend": [
        {
          "url_pattern": "/auth/{path}",
          "host": ["http://infinity-auth:8005"],
          "encoding": "no-op",
          "method": "GET"
        }
      ]
    },
    {
