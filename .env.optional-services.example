# Trancendos Optional Services — Environment Variables
# Copy to .env.optional-services and fill in values.
# Generate secrets: bash scripts/optional-services.sh gen-secrets

# ──────────────────────────────────────────────────────────────
# Shared
# ──────────────────────────────────────────────────────────────
TZ=UTC

# Infinity (SSO) — used by The Library OIDC
INFINITY_URL=http://localhost:8005
INFINITY_OIDC_CLIENT_ID=outline
INFINITY_OIDC_CLIENT_SECRET=change-me

# The Observatory URL (optional — for health event forwarding)
OBSERVATORY_URL=http://localhost:8007

# ──────────────────────────────────────────────────────────────
# The Library — Outline Wiki — Port 3300
# ──────────────────────────────────────────────────────────────
OUTLINE_SECRET_KEY=change-me-64-hex-chars
OUTLINE_UTILS_SECRET=change-me-64-hex-chars
OUTLINE_DB_PASSWORD=change-me-db-pass
OUTLINE_URL=http://localhost:3300

# ──────────────────────────────────────────────────────────────
# DocUtari — Paperless-ngx — Port 8765
# ──────────────────────────────────────────────────────────────
PAPERLESS_SECRET_KEY=change-me-64-hex-chars
PAPERLESS_DB_PASSWORD=change-me-db-pass
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=change-me-admin-pass
PAPERLESS_ADMIN_EMAIL=ops@trancendos.com
PAPERLESS_URL=http://localhost:8765

# ──────────────────────────────────────────────────────────────
# Fabulousa — Penpot Design — Port 9001
# ──────────────────────────────────────────────────────────────
PENPOT_SECRET_KEY=change-me-64-hex-chars
PENPOT_DB_PASSWORD=change-me-db-pass
PENPOT_PUBLIC_URI=http://localhost:9001
# Flags: enable-registration enable-login disable-email-verification
PENPOT_FLAGS=enable-registration enable-login disable-email-verification

# ──────────────────────────────────────────────────────────────
# The Workshop — Forgejo — Port 3456
# ──────────────────────────────────────────────────────────────
FORGEJO_ROOT_URL=https://trancendos.com/the-workshop
FORGEJO_DOMAIN=trancendos.com
FORGEJO_DISABLE_REGISTRATION=false
INSTALL_LOCK=false
RUNNER_IMAGE=code.forgejo.org/forgejo/runner:3
RUNNER_REGISTRATION_TOKEN=
FLY_API_TOKEN=
CF_API_TOKEN=

# ──────────────────────────────────────────────────────────────
# ChronosSphere — Cal.com — Port 3001
# ──────────────────────────────────────────────────────────────
CAL_NEXTAUTH_SECRET=change-me-64-hex-chars
CAL_DB_PASSWORD=change-me-db-pass
# Must be exactly 32 chars
CAL_ENCRYPTION_KEY=change-me-32-hex-chars-exactly!!
CAL_URL=http://localhost:3001
CAL_EMAIL_FROM=noreply@trancendos.com

# ──────────────────────────────────────────────────────────────
# The Artifactory — Zot OCI Registry — Port 5001
# (No secrets required for anonymous local use)
# ──────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────
# API Marketplace — Gravitee.io — Ports 8082/8083/8084
# ──────────────────────────────────────────────────────────────
GRAVITEE_MGMT_URL=http://localhost:8083

# ──────────────────────────────────────────────────────────────
# The Ice Box — Sandbox — Port 8090
# ──────────────────────────────────────────────────────────────
ICEBOX_SECRET_KEY=change-me-64-hex-chars
# Integration with Cryptex (Wazuh + MISP)
WAZUH_URL=http://localhost:55000
MISP_URL=http://localhost:8888
MISP_API_KEY=
