# EditorConfig — Consistent coding style across all editors
# https://editorconfig.org
# Updated: 2026-05 — Proactive Remediation & Automation

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 100

[*.{yml,yaml}]
indent_size = 2

[*.{json,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.sh]
indent_size = 2

[*.{js,ts,jsx,tsx}]
indent_size = 2

[*.css]
indent_size = 2
