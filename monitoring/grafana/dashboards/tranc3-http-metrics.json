{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "HTTP request metrics for all Tranc3 FastAPI workers (via prometheus-fastapi-instrumentator)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.95},
            {"color": "red", "value": 0.99}
          ]},
          "unit": "percentunit",
          "mappings": [],
          "min": 0, "max": 1
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 4, "x": 0, "y": 0},
      "id": 1,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "title": "Overall Success Rate (2xx)",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "expr": "sum(rate(http_requests_total{status=~\"2..\"}[5m])) / sum(rate(http_requests_total[5m]))",
        "legendFormat": "success rate"
      }]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}},
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 8, "x": 4, "y": 0},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background"},
      "title": "Request Rate (all workers)",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "expr": "sum(rate(http_requests_total[5m]))",
        "legendFormat": "req/s"
      }]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "s", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.5},
            {"color": "red", "value": 2.0}
          ]}
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "title": "P99 Latency (all workers)",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "expr": "histogram_quantile(0.99, sum by(le) (rate(http_request_duration_seconds_bucket[5m])))",
        "legendFormat": "p99"
      }]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "red", "value": 1}
          ]}
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "title": "5xx Errors (rate/min)",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) * 60",
        "legendFormat": "5xx/min"
      }]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 10}},
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 5},
      "id": 5,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Request Rate by Worker",
      "type": "timeseries",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "expr": "sum by(job) (rate(http_requests_total{job=~\"$worker\"}[5m]))",
        "legendFormat": "{{job}}"
      }]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "s", "color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1, "fillOpacity": 5}},
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 5},
      "id": 6,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "P95 Latency by Worker",
      "type": "timeseries",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "expr": "histogram_quantile(0.95, sum by(job, le) (rate(http_request_duration_seconds_bucket{job=~\"$worker\"}[5m])))",
        "legendFormat": "{{job}} p95"
      }]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "palette-classic"}, "custom": {"lineWidth": 1}},
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 14},
      "id": 7,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "right", "calcs": ["last", "max"]}},
      "title": "HTTP Status Breakdown by Worker",
      "type": "timeseries",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "expr": "sum by(job, status) (rate(http_requests_total{job=~\"$worker\"}[5m]))",
        "legendFormat": "{{job}} HTTP{{status}}"
      }]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"align": "left"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.5},
            {"color": "red", "value": 2.0}
          ]}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "p50"}, "properties": [{"id": "unit", "value": "s"}]},
          {"matcher": {"id": "byName", "options": "p95"}, "properties": [{"id": "unit", "value": "s"}]},
          {"matcher": {"id": "byName", "options": "p99"}, "properties": [{"id": "unit", "value": "s"}]},
          {"matcher": {"id": "byName", "options": "req/s"}, "properties": [{"id": "unit", "value": "reqps"}]},
          {"matcher": {"id": "byName", "options": "error%"}, "properties": [{"id": "unit", "value": "percent"}]}
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 23},
      "id": 8,
      "options": {"sortBy": [{"desc": true, "displayName": "req/s"}]},
      "title": "Worker SLO Summary Table",
      "type": "table",
      "transformations": [{"id": "merge", "options": {}}],
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by(job) (rate(http_requests_total{job=~\"$worker\"}[5m]))",
          "legendFormat": "{{job}}",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.50, sum by(job, le) (rate(http_request_duration_seconds_bucket{job=~\"$worker\"}[5m])))",
          "legendFormat": "{{job}}",
          "instant": true,
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.95, sum by(job, le) (rate(http_request_duration_seconds_bucket{job=~\"$worker\"}[5m])))",
          "legendFormat": "{{job}}",
          "instant": true,
          "refId": "C"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "histogram_quantile(0.99, sum by(job, le) (rate(http_request_duration_seconds_bucket{job=~\"$worker\"}[5m])))",
          "legendFormat": "{{job}}",
          "instant": true,
          "refId": "D"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "100 * sum by(job) (rate(http_requests_total{job=~\"$worker\", status=~\"5..\"}[5m])) / sum by(job) (rate(http_requests_total{job=~\"$worker\"}[5m]))",
          "legendFormat": "{{job}}",
          "instant": true,
          "refId": "E"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["tranc3", "http", "workers", "slo"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "definition": "label_values(http_requests_total, job)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "worker",
        "options": [],
        "query": {"query": "label_values(http_requests_total, job)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query",
        "label": "Worker"
      },
      {
        "current": {"selected": false, "text": "Prometheus", "value": "prometheus"},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Datasource"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Tranc3 — HTTP Metrics (Worker Fleet)",
  "uid": "tranc3-http-metrics",
  "version": 1
}
