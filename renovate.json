{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separatePatchReleases",
    "group:monorepos",
    "workarounds:all"
  ],
  "labels": ["dependencies", "automated"],
  "reviewers": ["Trancendos"],
  "assignees": ["Trancendos"],
  "baseBranchPatterns": [
    "main"
  ],
  "prCreation": "immediate",
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "platformAutomerge": false,
  "automerge": false,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "urgent"],
    "automerge": true,
    "automergeType": "pr"
  },
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "matchManagers": ["pip_requirements", "poetry", "pep621"],
      "matchUpdateTypes": ["patch"],
      "groupName": "Python patch updates",
      "automerge": true
    },
    {
      "matchManagers": ["pip_requirements", "poetry", "pep621"],
      "matchUpdateTypes": ["minor"],
      "groupName": "Python minor updates",
      "automerge": false
    },
    {
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Docker base image updates",
      "automerge": true
    },
    {
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Docker Compose service updates",
      "automerge": false
    },
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch"],
      "groupName": "Node.js patch updates",
      "automerge": true
    },
    {
      "matchUpdateTypes": ["major"],
      "enabled": false,
      "description": "Block major FastAPI/Uvicorn/Pydantic upgrades — require manual review",
      "matchPackageNames": [
        "/^fastapi$/",
        "/^uvicorn$/",
        "/^pydantic$/"
      ]
    },
    {
      "matchUpdateTypes": ["major", "minor"],
      "enabled": false,
      "description": "Block ML library upgrades — require manual compatibility testing",
      "matchPackageNames": [
        "/^torch$/",
        "/^transformers$/",
        "/^sentence-transformers$/"
      ]
    },
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["major"],
      "enabled": false,
      "description": "Block database major version upgrades — require migration planning",
      "matchPackageNames": [
        "/^postgres$/",
        "/^clickhouse$/"
      ]
    },
    {
      "matchManagers": ["terraform", "opentofu"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "OpenTofu provider updates",
      "automerge": false
    },
    {
      "groupName": "AI frameworks (LangChain / LlamaIndex / Haystack / DSPy)",
      "minimumReleaseAge": "7 days",
      "automerge": false,
      "labels": ["dependencies", "ai-framework"],
      "matchPackageNames": [
        "/^langchain/",
        "/^llama-index/",
        "/^llama_index/",
        "/^farm-haystack$/",
        "/^haystack-ai$/",
        "/^dspy-ai$/",
        "/^dspy$/"
      ]
    },
    {
      "matchPackageNames": ["fastapi", "uvicorn", "pydantic", "httpx", "starlette"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "FastAPI stack",
      "minimumReleaseAge": "3 days",
      "automerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "GitHub Actions",
      "automerge": true,
      "minimumReleaseAge": "1 day",
      "pinDigests": true
    }
  ],
  "ignorePaths": [
    "**/node_modules/**",
    "**/.venv/**",
    "**/venv/**",
    "**/__pycache__/**",
    "**/dist/**",
    "**/build/**"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(\\.forgejo\\/workflows\\/.*\\.yml$|\\.woodpecker\\.yml$)/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>.+?)\\n.*?(?<currentValue>[\\d.]+)"
      ],
      "description": "Parse inline Renovate annotations in CI workflows"
    }
  ],
  "schedule": ["after 2am and before 6am on monday"],
  "timezone": "Europe/London"
}
