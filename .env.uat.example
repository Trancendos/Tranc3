# TRANC3 — UAT (User Acceptance Testing) Environment Variables
# Copy to .env.uat
# NEVER commit .env files to git
#
# UAT environment: production-like config, isolated database, real integrations
# with test accounts/keys. Used for pre-production validation, stakeholder demos,
# and end-to-end acceptance tests.
#
# Key differences from Production:
#   - Separate database (tranc3_uat)
#   - Stripe test-mode keys
#   - Looser feature flags for testing new features
#   - Extended JWT expiry for demo sessions
#   - Debug logging enabled for test failure diagnosis

# ─── Core ──────────────────────────────────────────────────────────────────
ENVIRONMENT=uat
DEBUG=true
PORT=8000
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_STRONG_UAT_SECRET_KEY
LOG_LEVEL=INFO

# ─── Database ───────────────────────────────────────────────────────────────
# UAT: dedicated PostgreSQL database (separate from dev and prod)
DATABASE_URL=postgresql://tranc3_uat:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_URL=https://[uat-project-ref].supabase.co
SUPABASE_ANON_KEY=eyJ...   # UAT project anon key
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # UAT project service_role key

# ─── Cache ──────────────────────────────────────────────────────────────────
# UAT: dedicated Redis instance (separate from prod)
REDIS_URL=redis://tranc3-uat-redis:6379/0
# Or use Upstash free tier dedicated to UAT:
# REDIS_URL=rediss://:[password]@[uat-endpoint].upstash.io:6379

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_STRONG_UAT_JWT_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480   # 8h for UAT demo sessions

# ─── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://uat.trancendos.com,https://uat-api.trancendos.com
FRONTEND_URL=https://uat.trancendos.com
VITE_API_URL=https://uat-api.trancendos.com

# ─── AI Inference ───────────────────────────────────────────────────────────
# UAT: same free-tier fallback chain as production
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
HF_API_KEY=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ─── Model / Embeddings ─────────────────────────────────────────────────────
MODEL_PATH=./models/tranc3-base
TOKENIZER_MODEL=bert-base-multilingual-cased
CACHE_DIR=./cache
EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DIM=384
VECTOR_STORE_DIR=./data/vector_store

# ─── Vector DB ──────────────────────────────────────────────────────────────
PINECONE_API_KEY=   # UAT Pinecone key (separate namespace from prod)
PINECONE_ENV=gcp-starter
PINECONE_NAMESPACE=uat

# ─── Payments (test mode — NEVER use live keys in UAT) ─────────────────────
STRIPE_SECRET_KEY=sk_test_...   # Stripe test-mode key
STRIPE_WEBHOOK_SECRET=whsec_test_...
STRIPE_PRO_PRICE_ID=price_test_...
STRIPE_BUSINESS_PRICE_ID=price_test_...

# ─── Feature Flags ──────────────────────────────────────────────────────────
# UAT: all flags enabled to allow full acceptance testing
ENABLE_QUANTUM=true
ENABLE_CONSCIOUSNESS=true
ENABLE_NEUROMORPHIC=true
ENABLE_SELF_EVOLUTION=true
ENABLE_SWARM=true

# ─── Workers (internal ports — UAT uses same ports as prod, isolated by compose) ─
TRANC3_BACKEND_URL=https://uat-api.trancendos.com
INFINITY_WS_URL=http://tranc3-uat-ws:8004
INFINITY_AUTH_URL=http://tranc3-uat-auth:8005
INFINITY_AI_URL=http://tranc3-uat-ai:8009

# ─── Observability ──────────────────────────────────────────────────────────
# UAT: ship metrics to monitoring stack but separate Grafana dashboard
OTEL_EXPORTER_OTLP_ENDPOINT=http://tranc3-uat-otel:4317
GRAFANA_CLOUD_API_KEY=
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ─── The Void (secrets vault) ───────────────────────────────────────────────
VAULT_ADDR=http://tranc3-uat-vault:8200
VAULT_TOKEN=REPLACE_WITH_UAT_VAULT_TOKEN

# ─── Forgejo (The Workshop) ─────────────────────────────────────────────────
FORGEJO_URL=https://trancendos.com/the-workshop
FORGEJO_TOKEN=REPLACE_WITH_FORGEJO_TOKEN

# ─── Platform ───────────────────────────────────────────────────────────────
MAGNA_CARTA_ENABLED=true
MAGNA_CARTA_CONFIG_PATH=./magna_carta_config.json
TRANC3_AUTH_URL=https://uat-auth.trancendos.com
ALLOWED_ORIGINS=https://uat.trancendos.com,https://uat-api.trancendos.com

# ─── UAT-specific ───────────────────────────────────────────────────────────
# Used by test suites to target the UAT environment
UAT_BASE_URL=https://uat-api.trancendos.com
UAT_SMOKE_TEST_USER=smoke-test@trancendos.com
UAT_SMOKE_TEST_PASS=REPLACE_WITH_TEST_USER_PASSWORD
UAT_DATA_SEED=true   # Seed with demo data on startup
