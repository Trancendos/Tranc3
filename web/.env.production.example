# web/.env.production.example
# Copy to web/.env.production before production build.
# NEVER commit web/.env.production (it's in .gitignore).
#
# This file is committed as an example only.
#
# Build command:
#   VITE_API_URL=https://api.trancendos.com npm run build

# Production API base URL (no trailing slash)
# Self-hosted: https://api.trancendos.com
# Fly.io:      https://tranc3-backend.fly.dev
VITE_API_URL=https://api.trancendos.com

# WebSocket URL for The Nexus (The HIVE real-time events)
VITE_WS_URL=wss://api.trancendos.com/ws

# Ecosystem API (Infinity admin/AI)
VITE_ECOSYSTEM_API_URL=https://api.trancendos.com
