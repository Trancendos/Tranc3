# TRANC3 — Development Environment Variables
# Copy to .env.development (or .env for local dev)
# NEVER commit .env files to git
#
# Development environment: relaxed security, hot-reload, debug enabled,
# SQLite in place of PostgreSQL, local Redis, no external paid dependencies.

# ─── Core ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
PORT=8000
SECRET_KEY=dev-secret-key-change-for-any-shared-dev-env
LOG_LEVEL=DEBUG

# ─── Database ───────────────────────────────────────────────────────────────
# Development: SQLite for zero-setup (switch to Postgres if needed)
DATABASE_URL=sqlite:///./dev.db
# Uncomment to use local PostgreSQL instead:
# DATABASE_URL=postgresql://tranc3:tranc3dev@localhost:5432/tranc3_dev
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Cache ──────────────────────────────────────────────────────────────────
# Development: local Redis (see docker-compose.development.yml)
REDIS_URL=redis://localhost:6379/0

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-not-for-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24h for dev convenience

# ─── CORS ───────────────────────────────────────────────────────────────────
# Dev: permissive CORS; restrict in UAT/Prod
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8000

# ─── AI Inference (Free / Local) ────────────────────────────────────────────
# Tier 1: Local Ollama (preferred — zero cost, no network dependency)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text
# Tier 2: OpenRouter free models (cloud fallback)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
# Tier 3: HuggingFace Inference API free tier
HF_API_KEY=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ─── Model / Embeddings ─────────────────────────────────────────────────────
MODEL_PATH=./models/tranc3-base
TOKENIZER_MODEL=bert-base-multilingual-cased
CACHE_DIR=./cache
EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DIM=384
VECTOR_STORE_DIR=./data/vector_store

# ─── Vector DB ──────────────────────────────────────────────────────────────
# Dev: in-memory FAISS (no Pinecone key needed)
PINECONE_API_KEY=
PINECONE_ENV=

# ─── Payments (test mode) ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_dev_placeholder
STRIPE_WEBHOOK_SECRET=whsec_dev_placeholder
STRIPE_PRO_PRICE_ID=price_dev_placeholder
STRIPE_BUSINESS_PRICE_ID=price_dev_placeholder

# ─── Feature Flags ──────────────────────────────────────────────────────────
ENABLE_QUANTUM=true
ENABLE_CONSCIOUSNESS=true
ENABLE_NEUROMORPHIC=false
ENABLE_SELF_EVOLUTION=true
ENABLE_SWARM=false

# ─── Workers (internal ports — development) ─────────────────────────────────
TRANC3_BACKEND_URL=http://localhost:8000
INFINITY_WS_URL=http://localhost:8004
INFINITY_AUTH_URL=http://localhost:8005
INFINITY_AI_URL=http://localhost:8009

# ─── Observability ──────────────────────────────────────────────────────────
# Dev: lightweight — stdout logs, no external exporter
OTEL_EXPORTER_OTLP_ENDPOINT=
GRAFANA_CLOUD_API_KEY=
PROMETHEUS_ENABLED=false

# ─── The Void (secrets vault) ───────────────────────────────────────────────
# Dev: use dotenv directly (no Vault needed locally)
VAULT_ADDR=
VAULT_TOKEN=

# ─── Forgejo (The Workshop) ─────────────────────────────────────────────────
FORGEJO_URL=https://trancendos.com/the-workshop
FORGEJO_TOKEN=

# ─── Platform ───────────────────────────────────────────────────────────────
MAGNA_CARTA_ENABLED=false
MAGNA_CARTA_CONFIG_PATH=./magna_carta_config.json
TRANC3_AUTH_URL=http://localhost:8005
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
